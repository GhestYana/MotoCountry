# Скопіюй цей файл у backend/.env і заповни значення

PORT=5000
HOST=http://localhost
JWT_SECRET=your_jwt_secret_here

DB_USER=motostore_user
DB_PASSWORD=your_db_password
DB_HOST=localhost        # у Docker автоматично замінюється на "db"
DB_PORT=5432
DB_NAME=motostore

EMAIL_USER=your@gmail.com
EMAIL_PASS=your_app_password

CLOUD_NAME=your_cloudinary_name
CLOUD_API_KEY=your_cloudinary_key
CLOUD_API_SECRET=your_cloudinary_secret

FRONTEND_URL=http://localhost:5173   # у продакшені: http://localhost або ваш домен

LIQPAY_PUBLIC_KEY=your_liqpay_public_key
LIQPAY_PRIVATE_KEY=your_liqpay_private_key
LIQPAY_SANDBOX=1

NP_API_KEY=your_nova_poshta_api_key
MEEST_LOGIN=
MEEST_PASSWORD=
MEEST_CLIENT_UID=8458f0b0-930f-11e2-a91e-003048d2b473
